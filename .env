# =============================================================================
# WEBLOGIC INTEGRATED STACK - CONFIGURACIÓN + RED COMPARTIDA
# =============================================================================

# Información del Proyecto
PROJECT_NAME=weblogic-integrated-stack
COMPOSE_PROJECT_NAME=weblogic-integrated

# Zona Horaria
TZ=America/Bogota

# Build variables (se calculan en runtime)
BUILD_DATE=2025-09-08T19:22:45Z
BUILD_COMMIT=e2f72d8

# =============================================================================
# ORACLE DATABASE CONFIGURACIÓN
# =============================================================================
ORACLE_PWD=welcome1
ORACLE_SID=ORCLCDB
ORACLE_PDB=ORCLPDB1
ORACLE_CHARACTERSET=AL32UTF8
ORACLE_USER=system

# Nombres de Contenedores y Hostnames Oracle
IAOPS_ORACLE_CONTAINER=weblogic-oracle-main
ORACLE_HOSTNAME=weblogic-oracle-main

# =============================================================================
# WEBLOGIC A CONFIGURACIÓN (Versión Estable)
# =============================================================================
WEBLOGIC_A_ADMIN_PASSWORD=welcome1
WEBLOGIC_A_ADMIN_USER=weblogic
WEBLOGIC_A_DOMAIN_NAME=base_domain_a
APP_VERSION_A=1.0.0

# Nombres de Contenedores y Hostnames WebLogic A
IAOPS_WEBLOGIC_A_CONTAINER=weblogic-a-main
WEBLOGIC_A_HOSTNAME=weblogic-a-main

# =============================================================================
# WEBLOGIC B CONFIGURACIÓN (Versión Canary/Beta)
# =============================================================================
WEBLOGIC_B_ADMIN_PASSWORD=welcome1
WEBLOGIC_B_ADMIN_USER=weblogic
WEBLOGIC_B_DOMAIN_NAME=base_domain_b
APP_VERSION_B=2.0.0-beta

# Nombres de Contenedores y Hostnames WebLogic B
IAOPS_WEBLOGIC_B_CONTAINER=weblogic-b-main
WEBLOGIC_B_HOSTNAME=weblogic-b-main

# =============================================================================
# HAPROXY CONFIGURACIÓN
# =============================================================================
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=admin123
DEFAULT_STRATEGY=roundrobin
DEFAULT_WEIGHT_A=50
DEFAULT_WEIGHT_B=50

# Nombres de Contenedores y Hostnames HAProxy
IAOPS_HAPROXY_CONTAINER=weblogic-haproxy-main
HAPROXY_HOSTNAME=weblogic-haproxy-main

# =============================================================================
# PUERTOS EXTERNOS
# =============================================================================
EXTERNAL_ORACLE_PORT=1521
EXTERNAL_ORACLE_EM_PORT=5500
EXTERNAL_WEBLOGIC_A_PORT=7001
EXTERNAL_WEBLOGIC_B_PORT=7002
EXTERNAL_HTTP_PORT=8100
EXTERNAL_HTTPS_PORT=8443
EXTERNAL_STATS_PORT=8404
EXTERNAL_API_PORT=8081
EXTERNAL_UI_PORT=8082

# =============================================================================
# DASHBOARDS CONFIGURACIÓN
# =============================================================================
# Dashboard Unificado
IAOPS_UNIFIED_DASHBOARD_CONTAINER=weblogic-unified-dashboard
UNIFIED_DASHBOARD_HOSTNAME=weblogic-unified-dashboard

# Dashboard de Tráfico
IAOPS_TRAFFIC_DASHBOARD_CONTAINER=weblogic-traffic-dashboard
TRAFFIC_DASHBOARD_HOSTNAME=weblogic-traffic-dashboard

# Panel de Administración HAProxy
IAOPS_HAPROXY_ADMIN_CONTAINER=weblogic-haproxy-admin
HAPROXY_ADMIN_HOSTNAME=weblogic-haproxy-admin

# API de Administración
IAOPS_ADMIN_API_CONTAINER=weblogic-admin-api
ADMIN_API_HOSTNAME=weblogic-admin-api

# =============================================================================
# CONFIGURACIÓN DE REDES - HOMOLOGADAS CON IA-OPS
# =============================================================================
# Red interna de WebLogic
DOCKER_NETWORK_NAME=weblogic-integrated-network
WEBLOGIC_EXTERNAL_NETWORK_MODE=false

# RED COMPARTIDA PARA CONECTAR CON OTROS SERVICIOS IA-OPS
IAOPS_SHARED_NETWORK_NAME=iaops-shared-network
IAOPS_SHARED_NETWORK_EXTERNAL=false

# =============================================================================
# VOLÚMENES PERSISTENTES
# =============================================================================
ORACLE_DATA_VOLUME=weblogic_oracle_data
ORACLE_LOGS_VOLUME=weblogic_oracle_logs
WEBLOGIC_A_LOGS_VOLUME=weblogic_a_logs
WEBLOGIC_A_MONITORING_VOLUME=weblogic_a_monitoring
WEBLOGIC_B_LOGS_VOLUME=weblogic_b_logs
WEBLOGIC_B_MONITORING_VOLUME=weblogic_b_monitoring

# Network
SUBNET=172.27.0.0/16
GATEWAY=172.27.0.1
ENVIRONMENT=development
