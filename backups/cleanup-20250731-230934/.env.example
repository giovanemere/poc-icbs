# Configuración de Ejemplo para Docker Oracle WebLogic
# =====================================================
# Copia este archivo a .env y personaliza los valores

# Configuración de Base de Datos
# ==============================
DB_HOST=localhost
DB_PORT=1521
DB_SID=XE
DB_USER=weblogic
DB_PASSWORD=your_secure_password

# Configuración de WebLogic
# =========================
WEBLOGIC_ADMIN_USER=weblogic
WEBLOGIC_ADMIN_PASSWORD=welcome1
WEBLOGIC_DOMAIN_NAME=base_domain

# Configuración de HAProxy
# ========================
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=admin

# Configuración de Red
# ====================
NETWORK_NAME=weblogic_network
NETWORK_SUBNET=172.20.0.0/16

# Puertos de Servicios
# ====================
WEBLOGIC_ADMIN_PORT=7001
WEBLOGIC_MANAGED_1_PORT=7003
WEBLOGIC_MANAGED_2_PORT=7005
WEBLOGIC_CANARY_1_PORT=7007
WEBLOGIC_CANARY_2_PORT=7009
HAPROXY_MAIN_PORT=8080
HAPROXY_STATS_PORT=8404
DATABASE_PORT=1521

# Configuración de Recursos
# =========================
WEBLOGIC_MEMORY=2g
DATABASE_MEMORY=1g
CPU_LIMIT=2

# Configuración de Feature Flags
# ==============================
FF4J_ENABLED=true
FF4J_CONSOLE_ENABLED=true
FF4J_AUDIT_ENABLED=true

# Configuración de Canary
# =======================
CANARY_ENABLED=false
CANARY_TRAFFIC_PERCENTAGE=10
AB_TESTING_ENABLED=false

# Configuración de Logs
# =====================
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# Configuración de Desarrollo
# ===========================
DEVELOPMENT_MODE=true
HOT_DEPLOYMENT=true
DEBUG_ENABLED=true
DEBUG_PORT=5005

# Configuración de Seguridad
# ==========================
SSL_ENABLED=false
SSL_CERT_PATH=/path/to/certificate.pem
SSL_KEY_PATH=/path/to/private.key

# Configuración de Backup
# =======================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=7

# Variables de Entorno Adicionales
# ================================
JAVA_OPTS=-Xms1g -Xmx2g -XX:MaxPermSize=512m
TZ=America/Mexico_City
