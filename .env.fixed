# =============================================================================
# Archivo de Configuración de Variables de Entorno
# Proyecto: Docker Oracle WebLogic con Testing A/B, Canary Deployment y Feature Flags
# =============================================================================

# -----------------------------------------------------------------------------
# Configuración de Red Docker
# -----------------------------------------------------------------------------
NETWORK_NAME=weblogic-network
SUBNET=172.23.0.0/16

# -----------------------------------------------------------------------------
# Configuración de Oracle Database
# -----------------------------------------------------------------------------
ORACLE_SID=ORCLCDB
ORACLE_PDB=ORCLPDB1
ORACLE_PWD=Oracle123
ORACLE_CHARACTERSET=AL32UTF8
ORACLE_EDITION=enterprise

# IPs y Puertos de Oracle
ORACLE_HOST=172.23.0.2
ORACLE_PORT=1521
ORACLE_EM_PORT=5500

# Credenciales de Oracle
ORACLE_USER=system
ORACLE_PASSWORD=Oracle123
ORACLE_SCHEMA=weblogic_demo

# -----------------------------------------------------------------------------
# Configuración de WebLogic Server
# -----------------------------------------------------------------------------
# WebLogic A (Versión Estable)
WEBLOGIC_A_HOST=172.23.0.4
WEBLOGIC_A_PORT=7001
WEBLOGIC_A_ADMIN_USER=weblogic
WEBLOGIC_A_ADMIN_PASSWORD=welcome123
WEBLOGIC_A_DOMAIN_NAME=base_domain_a

# WebLogic B (Versión Canary/Beta)
WEBLOGIC_B_HOST=172.23.0.3
WEBLOGIC_B_PORT=7001
WEBLOGIC_B_ADMIN_USER=weblogic
WEBLOGIC_B_ADMIN_PASSWORD=welcome123
WEBLOGIC_B_DOMAIN_NAME=base_domain_b

# Configuración común de WebLogic
WEBLOGIC_MEMORY_ARGS="-Xms1024m -Xmx2048m -XX:MaxPermSize=256m"
WEBLOGIC_JAVA_OPTIONS="-Dweblogic.StdoutDebugEnabled=false"

# -----------------------------------------------------------------------------
# Configuración de HAProxy
# -----------------------------------------------------------------------------
HAPROXY_HOST=172.23.0.5
HAPROXY_HTTP_PORT=80
HAPROXY_HTTPS_PORT=443
HAPROXY_STATS_PORT=8404
HAPROXY_API_PORT=8081
HAPROXY_UI_PORT=8082

# Credenciales de HAProxy Stats
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=admin123

# Configuración de balanceeo por defecto
DEFAULT_STRATEGY=roundrobin
DEFAULT_WEIGHT_A=50
DEFAULT_WEIGHT_B=50

# -----------------------------------------------------------------------------
# Configuración de Puertos Externos
# -----------------------------------------------------------------------------
# HAProxy
EXTERNAL_HTTP_PORT=8080
EXTERNAL_HTTPS_PORT=8443
EXTERNAL_STATS_PORT=8404
EXTERNAL_API_PORT=8081
EXTERNAL_UI_PORT=8082

# WebLogic
EXTERNAL_WEBLOGIC_A_PORT=7001
EXTERNAL_WEBLOGIC_B_PORT=7002

# Oracle
EXTERNAL_ORACLE_PORT=1521
EXTERNAL_ORACLE_EM_PORT=5500

# -----------------------------------------------------------------------------
# Configuración de Feature Flags (FF4J)
# -----------------------------------------------------------------------------
FF4J_CONSOLE_ENABLED=true
FF4J_AUDIT_ENABLED=true
FF4J_MONITORING_ENABLED=true
FF4J_WEBCONSOLE_EMBEDDED=true

# -----------------------------------------------------------------------------
# Configuración de Aplicaciones
# -----------------------------------------------------------------------------
# Versiones de aplicaciones
APP_VERSION_A=1.0.0
APP_VERSION_B=2.0.0-beta

# Contextos de aplicaciones
CONTEXT_VERSION_A=/version-a
CONTEXT_VERSION_B=/version-b
CONTEXT_FEATURE_FLAGS=/feature-flags
CONTEXT_FF4J=/ff4j-simple
CONTEXT_WEBLOGIC_FEATURES_A=/weblogic-features-a
CONTEXT_WEBLOGIC_FEATURES_B=/weblogic-features-b

# -----------------------------------------------------------------------------
# Configuración de Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_MAX_SIZE=100m
LOG_MAX_FILES=5

# Directorios de logs
LOGS_DIR=./logs
HAPROXY_LOGS_DIR=./logs/haproxy
WEBLOGIC_LOGS_DIR=./logs/weblogic
ORACLE_LOGS_DIR=./logs/oracle

# -----------------------------------------------------------------------------
# Configuración de Volúmenes
# -----------------------------------------------------------------------------
# Directorios de datos persistentes
ORACLE_DATA_DIR=./data/oracle
WEBLOGIC_A_DATA_DIR=./data/weblogic-a
WEBLOGIC_B_DATA_DIR=./data/weblogic-b
HAPROXY_CONFIG_DIR=./haproxy/config

# Directorios de despliegue
DEPLOY_DIR=./deploy
AUTODEPLOY_DIR=./autodeploy

# -----------------------------------------------------------------------------
# Configuración de Desarrollo
# -----------------------------------------------------------------------------
# Modo de desarrollo (true/false)
DEVELOPMENT_MODE=true
DEBUG_MODE=false

# Configuración de hot-reload
HOT_RELOAD_ENABLED=true
AUTO_DEPLOY_ENABLED=true

# -----------------------------------------------------------------------------
# Configuración de Monitoreo y Métricas
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30s

# URLs de health checks
WEBLOGIC_A_HEALTH_URL=http://172.23.0.4:7001/health
WEBLOGIC_B_HEALTH_URL=http://172.23.0.3:7001/health

# -----------------------------------------------------------------------------
# Configuración de Seguridad
# -----------------------------------------------------------------------------
# SSL/TLS
SSL_ENABLED=false
SSL_CERT_PATH=./certs/server.crt
SSL_KEY_PATH=./certs/server.key

# Configuración de CORS
CORS_ENABLED=true
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Configuración de Testing A/B y Canary
# -----------------------------------------------------------------------------
# Estrategias disponibles: roundrobin, ab_testing, canary
DEPLOYMENT_STRATEGY=roundrobin

# Configuración A/B Testing
AB_TESTING_ENABLED=false
AB_TESTING_PERCENTAGE_A=70
AB_TESTING_PERCENTAGE_B=30

# Configuración Canary Deployment
CANARY_ENABLED=false
CANARY_PERCENTAGE=10
CANARY_RAMP_UP_INTERVAL=300s

# -----------------------------------------------------------------------------
# Configuración de Cache
# -----------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL=3600
BROWSER_CACHE_CONTROL=no-cache

# -----------------------------------------------------------------------------
# Configuración de Timezone y Localización
# -----------------------------------------------------------------------------
TZ=America/Mexico_City
LANG=es_ES.UTF-8
LC_ALL=es_ES.UTF-8

# -----------------------------------------------------------------------------
# Configuración de Recursos
# -----------------------------------------------------------------------------
# Límites de memoria para contenedores
ORACLE_MEMORY_LIMIT=2g
WEBLOGIC_A_MEMORY_LIMIT=2g
WEBLOGIC_B_MEMORY_LIMIT=2g
HAPROXY_MEMORY_LIMIT=512m

# Límites de CPU
ORACLE_CPU_LIMIT=2
WEBLOGIC_A_CPU_LIMIT=2
WEBLOGIC_B_CPU_LIMIT=2
HAPROXY_CPU_LIMIT=1

# -----------------------------------------------------------------------------
# Variables de Build
# -----------------------------------------------------------------------------
BUILD_DATE=""
BUILD_VERSION="1.0.0"
BUILD_COMMIT="latest"

# Configuración de Maven (para builds)
MAVEN_OPTS="-Xmx1024m"
JAVA_HOME="/usr/lib/jvm/java-11-openjdk"

# -----------------------------------------------------------------------------
# Configuración de Backup
# -----------------------------------------------------------------------------
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=./backups

# -----------------------------------------------------------------------------
# Variables de Entorno Específicas del Sistema
# -----------------------------------------------------------------------------
# Usuario y grupo para contenedores
CONTAINER_USER=oracle
CONTAINER_GROUP=oracle
CONTAINER_UID=1000
CONTAINER_GID=1000

# Configuración de hosts
EXTRA_HOSTS="weblogic-a:172.23.0.4,weblogic-b:172.23.0.3,oracle-db:172.23.0.2,haproxy:172.23.0.5"
